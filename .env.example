# Database
DATABASE_URL=mysql://root:root@mysql:3306/hovod
REDIS_URL=redis://redis:6379
PORT=3000

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=hovod-vod
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/hovod-vod

# Shared upload directory (API writes, Worker reads — must be same volume)
# UPLOAD_DIR=/data/uploads

# Dashboard & CORS
DASHBOARD_URL=http://localhost:3003
CORS_ORIGIN=http://localhost:3003,http://localhost:3002
VITE_API_BASE_URL=http://localhost:3002

# Security — REQUIRED
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# ─── Registration (optional — open by default) ─────────
# REGISTRATION_ENABLED=true                  # set to false to disable new signups
# REGISTRATION_ALLOWED_DOMAINS=example.com   # comma-separated list of allowed email domains

# Docker Compose credentials (change these in production)
# MYSQL_ROOT_PASSWORD=change-me-in-production
# MINIO_ROOT_USER=change-me-in-production
# MINIO_ROOT_PASSWORD=change-me-in-production

# ─── Scaling (optional — auto-detected from hardware) ────
# WORKER_CONCURRENCY=2            # concurrent transcode jobs (default: auto from CPU/RAM)
# FFMPEG_THREADS=4                # threads per FFmpeg process (default: auto from CPU/concurrency)
# DB_POOL_SIZE=20                 # MySQL connection pool size (default: auto from RAM)

# ─── AI Processing (optional — omit to disable) ─────────
# Whisper-compatible transcription API (OpenAI, Groq, local, etc.)
# WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
# WHISPER_API_KEY=sk-...
# WHISPER_MODEL=whisper-1

# LLM for chapter generation (openai | anthropic | groq | custom)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_API_URL=                  # custom endpoint (leave empty for default)
#
# Groq example:
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# AI_ENABLED=true               # set to false to disable AI even if configured

# ─── Billing (optional — omit all for unlimited usage) ───
# Adding Stripe keys enables tiered billing, usage metering, and plan limits.
# Without Stripe, all features are available with no usage restrictions.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_BUSINESS_PRICE_ID=price_...

# ─── Webhooks (optional) ────────────────────────────────
# WEBHOOK_URL=https://your-app.com/webhook
